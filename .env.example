# Supabase (auth, données)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxx

# Optionnel : lien affilié Carrefour Drive (Kwanko)
# Si défini, le bouton "Carrefour Drive" utilisera cette URL et une mention "lien partenaire" s'affichera.
# VITE_CARREFOUR_DRIVE_URL=https://www.carrefour.fr/drive?

# Optionnel : Google Calendar (ajout direct des repas sans fichier .ics)
# Créer un projet Google Cloud, activer l'API Calendar, créer des identifiants OAuth 2.0 (application Web),
# ajouter les origines JavaScript autorisées (ex. https://www.mamie-vege.fr, http://localhost:5173).
# VITE_GOOGLE_CALENDAR_CLIENT_ID=xxx.apps.googleusercontent.com...

# Audit SEO quotidien (Vercel Cron)
CRON_SECRET=xxx                            # Généré par Vercel (Settings > Cron Jobs)
ANTHROPIC_API_KEY=sk-ant-xxx               # console.anthropic.com
BREVO_API_KEY=xkeysib-xxx                  # app.brevo.com > SMTP & API > API Keys
EMAIL_FROM=audit@mamie-vege.fr             # Expéditeur (doit être vérifié dans Brevo)
EMAIL_TO=ton@email.com                     # Destinataire du rapport
